# ============================================================
#  Copy this file to .env and fill in the values.
#  $ cp .env.example .env
# ============================================================

# -- Discord --------------------------------------------------
# Bot token from Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# Channel ID where the calendar will be posted
DISCORD_CHANNEL_ID=

# -- Google Calendar ------------------------------------------
# Service account email (e.g. bot@project.iam.gserviceaccount.com)
GOOGLE_CLIENT_EMAIL=

# Service account private key (from JSON file, "private_key" field)
# Keep the \n as-is, wrap the whole value in double quotes
GOOGLE_PRIVATE_KEY=""

# Google Calendar ID (usually an email address or "primary")
GOOGLE_CALENDAR_ID=

# -- Roles & Channels (optional) ------------------------------
# Discord role name allowed to add/edit/delete events
# Default: CalendarOperator
OPERATOR_ROLE_NAME=CalendarOperator

# Channel ID for notification messages (default: DISCORD_CHANNEL_ID)
NOTIFY_CHANNEL_ID=

# Channel ID for audit log messages (leave empty to disable)
LOG_CHANNEL_ID=

# -- Cron (optional) ------------------------------------------
# How often to sync with Google Calendar (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *
