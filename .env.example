# ============================================================
#  Copy this file to .env and fill in the values.
#  $ cp .env.example .env
#
#  v5: マルチギルド対応
#  チャンネル・カレンダーID・ロール等はサーバーごとに
#  /setup コマンドで設定します。ここでは不要です。
# ============================================================

# -- Discord --------------------------------------------------
# Bot token from Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# -- Google Calendar ------------------------------------------
# Service account email (e.g. bot@project.iam.gserviceaccount.com)
# サービスアカウントのメールを各サーバーのカレンダーに「編集者」共有してもらう
GOOGLE_CLIENT_EMAIL=

# Service account private key (from JSON file, "private_key" field)
# Keep the \n as-is, wrap the whole value in double quotes
GOOGLE_PRIVATE_KEY=""

# -- Cron (optional) ------------------------------------------
# How often to sync with Google Calendar (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# ============================================================
#  以下は v4 以前の設定です。v5 では /setup コマンドに移行しました。
#  削除済み: DISCORD_CHANNEL_ID, GOOGLE_CALENDAR_ID,
#             OPERATOR_ROLE_NAME, NOTIFY_CHANNEL_ID, LOG_CHANNEL_ID
# ============================================================
