# ============================================================
#  スケジュール管理 Discord Bot — 環境変数テンプレート
#  このファイルをコピーして .env にリネームし、値を設定してください
#  $ cp .env.template .env
# ============================================================

# ── Discord ─────────────────────────────────────────────────
# Bot トークン（Discord Developer Portal → Bot → Token）
DISCORD_TOKEN=MTExxxxxxxxxxxxxxxxxxx.Xxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxx

# カレンダーと操作ボタンを投稿するチャンネルの ID
DISCORD_CHANNEL_ID=1234567890123456789

# ── Google Calendar ──────────────────────────────────────────
# サービスアカウントのメールアドレス（例: bot@project.iam.gserviceaccount.com）
GOOGLE_CLIENT_EMAIL=my-bot@my-project-123456.iam.gserviceaccount.com

# サービスアカウントの秘密鍵（JSON の private_key をそのままペースト。\n はそのままでOK）
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...(省略)...QClm\n-----END RSA PRIVATE KEY-----\n"

# 対象 Google カレンダーの ID（通常はサービスアカウントを共有したカレンダーのメールアドレス形式）
GOOGLE_CALENDAR_ID=myteam.schedule@gmail.com

# ── 権限・チャンネル設定 ──────────────────────────────────────
# 予定の追加・編集・削除を許可するロール名（省略時: CalendarOperator）
OPERATOR_ROLE_NAME=CalendarOperator

# 通知メッセージを送信するチャンネルの ID（省略時: DISCORD_CHANNEL_ID と同じ）
NOTIFY_CHANNEL_ID=9876543210987654321

# 操作ログ（追加・編集・削除）を送信するチャンネルの ID（省略でログなし）
LOG_CHANNEL_ID=1122334455667788990

# ── cron スケジュール（省略可） ───────────────────────────────
# Google カレンダーとの同期間隔（省略時: 5分ごと）
CRON_SCHEDULE=*/5 * * * *
